{
  "name": "docintel",
  "version": "1.0.0",
  "private": true,
  "description": "AI Contract Analysis Platform - Analyze contracts with AI-powered insights",
  "scripts": {
    "dev": "pnpm run dev:services",
    "dev:services": "pnpm run --parallel dev:frontend dev:backend",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:worker": "cd apps/worker && python run.py",
    "build": "pnpm run build:packages && pnpm run build:apps",
    "build:packages": "pnpm --filter @docintel/* build",
    "build:apps": "pnpm --filter frontend --filter backend build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean && rimraf node_modules",
    "docker:up": "docker-compose -f infrastructure/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker-compose.yml down",
    "docker:build": "docker-compose -f infrastructure/docker-compose.yml build"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
