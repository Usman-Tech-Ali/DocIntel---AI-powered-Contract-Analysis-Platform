{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmit": true,
    "incremental": true,
    "paths": {
      "@docintel/types": ["./packages/types/src"],
      "@docintel/utils": ["./packages/utils/src"],
      "@docintel/ui": ["./packages/ui/src"],
      "@docintel/config": ["./packages/config/src"]
    }
  },
  "exclude": ["node_modules", "dist", "**/dist", "**/node_modules", "apps/worker"]
}

